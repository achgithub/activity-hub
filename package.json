{
  "name": "activity-hub-monorepo",
  "version": "1.0.0",
  "description": "Activity Hub - Open-source pub gaming and social platform",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/ui",
    "packages/sdk",
    "frontend"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "build:packages": "pnpm -r --filter '@activity-hub/*' build",
    "build:frontend": "pnpm -F frontend build",
    "dev": "pnpm -r --parallel dev",
    "install": "pnpm install",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "pnpm": "^8.0.0",
    "typescript": "^4.9.5"
  }
}
